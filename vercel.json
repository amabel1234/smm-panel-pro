{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/smm-panel run build",
  "outputDirectory": "artifacts/smm-panel/dist/public",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}